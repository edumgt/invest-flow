# ══════════════════════════════════════════════════════════════════════════
# .env.office — 사무실 인하우스 개발 환경 (docker-compose.office.yml, VMware 베어메탈 호스트)
#
# 사용법:
#   cp .env.office.example .env.office
#   docker compose --env-file .env.office -f docker-compose.office.yml up --build -d
#
# 전제: Postgres/Ollama 는 컨테이너가 아니라 호스트(Windows/VMware)에 직접 설치되어 있고,
#       컨테이너에서는 host.docker.internal 로 접근한다.
# ══════════════════════════════════════════════════════════════════════════

# ─── Backend ─────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-secret
CORS_ORIGIN=http://localhost:5173,http://localhost:8302

# ─── Database (호스트에 직접 설치된 Postgres) ──────────────────────────────
DATABASE_URL=postgresql://calendar:calendar123@host.docker.internal:5432/calendar_app

# ─── Ollama (호스트 GPU, Windows/VMware) ──────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11300
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_VISION_MODEL=llava:34b

# ─── Airflow (사내 전용 VM, ansible 10-airflow-install.yml 로 프로비저닝) ──
AIRFLOW_URL=http://192.168.253.149:8793
AIRFLOW_USER=admin
AIRFLOW_PASS=admin

# ─── Data 저장 경로 (컨테이너 내부 마운트 경로, 고정값) ────────────────────
DATA_ROOT=/data

# ─── Frontend ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8301

# ─── docker-compose.airflow.yml 를 이 호스트에서도 함께 띄울 때만 필요 ─────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
GITLAB_URL=http://gitlab.local:8080
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
