# ══════════════════════════════════════════════════════════════════════════
# .env.aws — AWS Cloud 환경 (docker-compose.aws.yml, EC2 + ALB)
#
# 사용법:
#   cp .env.aws.example .env.aws
#   docker compose --env-file .env.aws -f docker-compose.aws.yml up --build -d
#
# 값들은 EC2 인스턴스에 직접 컨테이너로 Postgres를 띄우는 것을 전제로 한다.
# RDS로 옮기는 경우 docker-compose.aws.yml 에서 postgres 서비스를 제거하고
# DATABASE_URL만 RDS 엔드포인트로 교체하면 된다.
# ══════════════════════════════════════════════════════════════════════════

# ─── Backend ─────────────────────────────────────────────────────────────
PORT=3000
# 반드시 운영 배포 전 강력한 값으로 교체 (AWS Secrets Manager / SSM Parameter Store 권장)
JWT_SECRET=CHANGE_ME_USE_SECRETS_MANAGER
# ALB 뒤 실제 도메인으로 교체
CORS_ORIGIN=https://invest-flow.example.com

# ─── Database (같은 compose 안의 postgres 컨테이너) ────────────────────────
POSTGRES_USER=calendar
POSTGRES_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
POSTGRES_DB=calendar_app
DATABASE_URL=postgresql://calendar:CHANGE_ME_USE_SECRETS_MANAGER@postgres:5432/calendar_app

# ─── Ollama (GPU 인스턴스가 없으므로 별도 GPU 인스턴스/사내망 엔드포인트 필수 지정) ─
OLLAMA_URL=http://CHANGE_ME_OLLAMA_HOST:11434
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_VISION_MODEL=llava:34b

# ─── Airflow 프록시 대상 (docker-compose.airflow.yml 함께 기동 시 또는 MWAA 등) ─
AIRFLOW_URL=http://airflow-webserver:8793
AIRFLOW_USER=admin
AIRFLOW_PASS=CHANGE_ME_USE_SECRETS_MANAGER

# ─── Data 저장 경로 (컨테이너 내부 마운트 경로, 고정값 — named volume 사용) ─
DATA_ROOT=/data

# ─── Frontend (ALB 도메인으로 교체) ─────────────────────────────────────────
VITE_API_URL=https://invest-flow.example.com/api

# ─── docker-compose.airflow.yml 를 같은 인스턴스에서 함께 띄울 때만 필요 ────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
GITLAB_URL=
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
