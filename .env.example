VITE_API_URL=http://localhost:3000

# ─── GitLab 연동 설정 ───────────────────────────────────────────────────────
# GitLab 인스턴스 URL (Docker로 로컬 실행 시 기본값)
GITLAB_URL=http://gitlab.local:8080
# GitLab Personal Access Token (api scope 필요)
GITLAB_TOKEN=
# GitLab 프로젝트 경로 또는 숫자 ID (예: edumgt/Vue_vite_tailwind_tui.calendar)
GITLAB_PROJECT_ID=
# GitLab 프로젝트 경로 (GitHub Actions 미러링용)
GITLAB_PROJECT_PATH=edumgt/Vue_vite_tailwind_tui.calendar

# ─── Airflow 설정 ───────────────────────────────────────────────────────────
# Airflow 웹서버 포트
AIRFLOW_WEBSERVER_PORT=8793
# Airflow 관리자 계정
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
# Airflow UID (Linux 환경: id -u 명령으로 확인)
AIRFLOW_UID=50000
