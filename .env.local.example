# ══════════════════════════════════════════════════════════════════════════
# .env.local — 로컬 Docker 개발 환경 (docker-compose.local.yml)
#
# 사용법:
#   cp .env.local.example .env.local
#   docker compose --env-file .env.local -f docker-compose.local.yml up --build -d
#
# 전제: shared-net 외부 네트워크에 공유 postgres / ollama 컨테이너가 이미 떠 있어야 함
#       (edumgt-lab-init/infra 의 docker-compose 로 기동되는 인프라)
# ══════════════════════════════════════════════════════════════════════════

# ─── Backend ─────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:8302

# ─── Database (shared-net 의 공유 postgres 컨테이너) ───────────────────────
DATABASE_URL=postgresql://calendar:calendar123@postgres:5432/calendar_app

# ─── Ollama (shared-net 의 공유 ollama 컨테이너, AI 투자 추천 / 이미지 분류) ─
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_VISION_MODEL=llava:34b

# ─── Airflow 프록시 대상 (docker-compose.airflow.yml 함께 기동 시) ─────────
AIRFLOW_URL=http://airflow-webserver:8793
AIRFLOW_USER=admin
AIRFLOW_PASS=admin

# ─── Data 저장 경로 (컨테이너 내부 마운트 경로, 고정값) ────────────────────
DATA_ROOT=/data

# ─── Frontend ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8301

# ─── docker-compose.airflow.yml 를 함께 띄울 때만 필요 ─────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
GITLAB_URL=http://gitlab.local:8080
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
